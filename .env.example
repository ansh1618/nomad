# =============================================================
# NOMADIK — Environment Variables Template
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git. Only .env.example is safe to commit.
# =============================================================

# --- Supabase ---
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# --- Cashfree Payments ---
# Get from: https://merchant.cashfree.com → Credentials
CASHFREE_APP_ID="YOUR_CASHFREE_APP_ID"
CASHFREE_SECRET_KEY="YOUR_CASHFREE_SECRET_KEY"
CASHFREE_ENVIRONMENT="SANDBOX"   # Change to "PRODUCTION" for live

# --- App URL ---
# Used for Cashfree return/notify callback URLs
VITE_APP_URL="http://localhost:8080"

# --- Resend (Email) --- optional
RESEND_API_KEY="YOUR_RESEND_API_KEY"
